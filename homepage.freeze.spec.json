      "mobile_font_size": "48px",
      "mobile_breakpoint": "max-width: 767px"
    },
    "headings": {
      "margin": "0 0 1.4rem"
    },
    "p": {
      "font_size": "1rem",
      "margin": "0 0 1.4rem"
    },
    "anchor": {
